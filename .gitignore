# CloudCost Sentinel - Git Ignore File

# AWS Credentials (CRITICAL - NEVER COMMIT)
.aws/
*.pem
*.key
credentials
config
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
ENV/
env/
.venv

# Data Files (contains sensitive cost data)
data/*.csv
data/*.json
data/*.xlsx
!data/.gitkeep

# Logs (may contain sensitive info)
logs/*.log
logs/*.txt
!logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# Tableau
*.twb
*.twbx
*.tds
*.tdsx
*.hyper
!screenshots/*.png

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# OS
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.bak
*.backup
temp/
tmp/

# API Keys and Secrets
secrets.json
api_keys.txt
*.secret